datasource db {
  provider = "postgresql"
  url      = env("DATABASE_URL")
}

generator client {
  provider = "prisma-client-js"
}

model User {
  id        String   @id @default(uuid())
  email     String   @unique
  createdAt DateTime @default(now())

  subscription Subscription?
}

model Subscription {
  id        String   @id @default(uuid())
  userId    String   @unique
  plan      String
  status    String
  usage     Int      @default(0)
  limit     Int

  user User @relation(fields: [userId], references: [id])
}

model Payment {
  id        String   @id @default(uuid())
  userId    String
  amount    Float
  status    String
  createdAt DateTime @default(now())
}
